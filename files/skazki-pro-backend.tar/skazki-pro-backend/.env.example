# ═══════════════════════════════════════
# СказкиПро Backend — Environment Variables
# ═══════════════════════════════════════

# Required: ElevenLabs API Key
# Get it at: https://elevenlabs.io/app/settings/api-keys
# Minimum plan: Creator ($22/mo) — needed for voice cloning API access
ELEVENLABS_API_KEY=your_api_key_here

# Optional: Google Sheets webhook for email collection
# Create via Google Apps Script (see README)
# GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Optional: Telegram notifications for new signups
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
